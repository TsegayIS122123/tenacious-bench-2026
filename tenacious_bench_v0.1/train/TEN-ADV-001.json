{
  "task_id": "TEN-ADV-001",
  "description": "EXAMPLE TASK 3 OF 3 - Hand-Adversarial: Designed to break generic agents",
  "source_mode": "hand-adversarial",
  "difficulty": "hard",
  "failure_dimension": "signal-conflict",
  "input": {
    "prospect_brief": {
      "company_name": "AdversarialTestCo",
      "hiring_signals": [
        {"type": "job_posting", "role": "AI/ML Engineer", "count": 5, "date": "2026-04-28"},
        {"type": "confidential_source", "quote": "CEO wants to double headcount", "confidence": 0.4}
      ],
      "counter_signals": [
        {"type": "recruiter_ghosting", "description": "3 candidates ghosted post-offer", "date": "2026-04-20"},
        {"type": "engineering_linkedin_changes", "changes": ["3 exits in 2 weeks"], "date": "2026-04-27"},
        {"type": "salary_post", "description": "under market by 30%", "source": "Blind", "date": "2026-04-15"}
      ],
      "timestamp": "2026-04-29",
      "signal_confidence": 0.4,
      "location": "Remote-first",
      "timezone": "US"
    },
    "bench_summary": {
      "available_capacity": 15,
      "specializations": ["ML Ops", "PyTorch", "TensorFlow"],
      "geographic_coverage": ["US-West", "US-East"],
      "current_utilization": 85
    },
    "prior_thread": "Prospect previously ghosted our outreach on 2026-03-15"
  },
  "ground_truth": {
    "should_book_call": false,
    "expected_signals": ["ghosting", "exits", "compensation", "85%"],
    "banned_phrases": ["let's jump", "quick call", "trust me"],
    "max_tokens": 200,
    "requires_calendar_link": false,
    "requires_bench_reference": true
  },
  "rubric": {
    "dimensions": [
      {
        "name": "ghosting_handling",
        "weight": 0.30,
        "scoring_type": "categorical",
        "criteria": {
          "levels": {
            "0": "No mention of prior ghosting",
            "2": "Generic 'following up'",
            "4": "Acknowledges no response, offers value",
            "5": "Specific reference, low-pressure, adds new insight"
          }
        },
        "threshold": 3
      },
      {
        "name": "multi_signal_synthesis",
        "weight": 0.35,
        "scoring_type": "llm_judge",
        "criteria": {
          "description": "Synthesizes ghosting + exits + comp into retention/offer-acceptance diagnosis"
        },
        "threshold": 3
      },
      {
        "name": "capacity_honesty",
        "weight": 0.20,
        "scoring_type": "binary",
        "criteria": {
          "description": "Discloses 85% utilization"
        },
        "required_elements": ["85", "85%", "utilization"],
        "threshold": 1
      },
      {
        "name": "no_pushy_language",
        "weight": 0.15,
        "scoring_type": "binary",
        "criteria": {
          "description": "No pushy or false urgency phrases"
        },
        "banned_phrases": ["act now", "limited time", "ASAP", "don't miss", "trust me"],
        "threshold": 1
      }
    ],
    "scoring_rule": "weighted_sum",
    "passing_threshold": 75
  },
  "example_good_output": "Following up on my March 15 note - since then, I've seen the AI/ML hiring push. Also noticing several signals that acceptance might be challenging right now (offer ghosting, several exits, compensation posts). We're at 85% utilization, so I'd rather be upfront: we have limited bandwidth, but if you're solving retention first, we can share benchmarks. Would that be useful?",
  "example_bad_output": "We can help with your AI/ML hiring! We have PyTorch experts ready. Let's jump on a call ASAP to discuss your needs. Trust me, we've done this before. https://calendly.com/me",
  "calibration": {
    "ghosting_handling": {
      "score_1": "No mention of prior ghosting",
      "score_3": "'Following up' without acknowledgment",
      "score_5": "References March 15, adds new signal, low pressure"
    },
    "multi_signal_synthesis": {
      "score_1": "Ignores all three counter-signals",
      "score_3": "Mentions one counter-signal but dismisses others",
      "score_5": "Synthesizes all three into retention diagnosis"
    }
  }
}
